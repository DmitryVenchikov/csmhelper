//  SMART SCHEDULING
// ══════════════════════════════════════════════════════════════
document.getElementById('schedCalc').addEventListener('click', async () => {
    const memberId = document.getElementById('schedMember').value;
    const start    = document.getElementById('schedStart').value;
    const days     = document.getElementById('schedDays').value;
    const result   = document.getElementById('schedResult');

    if (!memberId || !start || !days) { result.innerHTML = '<span class="text-danger">Заполните все поля</span>'; return; }

    result.innerHTML = '<span class="text-muted">Вычисляю…</span>';
    const res = await fetch(`/Gantt/ComputeEnd?memberId=${memberId}&start=${start}&workDays=${days}`);
    const json = await res.json();
    if (!json.success) { result.innerHTML = `<span class="text-danger">${esc(json.error)}</span>`; return; }

    const member = ganttData.members.find(m => m.id === memberId);
    let html = `<strong>Дата окончания:</strong> ${json.effectiveEnd}<br>`;
    if (json.vacationDaysOverlap > 0) {
        html += `<span class="text-danger">⚠️ Пропущено отпускных дней: <strong>${json.vacationDaysOverlap}</strong></span><br>`;
        html += `<span class="text-muted">(без учёта: ${json.originalEnd})</span>`;
    } else {
        html += `<span class="text-success">✓ Отпуска не пересекаются</span>`;
    }
    result.innerHTML = html;
});

// ══════════════════════════════════════════════════════════════
//  HELPERS
// ══════════════════════════════════════════════════════════════
function parseDate(str) {
    if (!str) return null;
    const d = new Date(str);
    d.setHours(0,0,0,0);
    return isNaN(d) ? null : d;
}

function fmt(d) {
    return d.toISOString().substring(0,10);
}

function addDays(d, n) {
    const r = new Date(d);
    r.setDate(r.getDate() + n);
    return r;
}

function daysBetween(a, b) {
    return Math.round((b - a) / 86400000);
}

function shortDate(str) {
    if (!str) return '—';
    const d = new Date(str);
    return d.toLocaleDateString('ru-RU', {day:'numeric', month:'short'});
}

function esc(s) {
    if (!s) return '';
    return String(s)
        .replace(/&/g,'&amp;')
        .replace(/</g,'&lt;')
        .replace(/>/g,'&gt;')
        .replace(/"/g,'&quot;');
}

function jsonH() {
    return { 'Content-Type': 'application/json' };
}
