@{
    ViewData["Title"] = "Диаграмма Ганта";
}

@section Styles {
<style>
/* ── Layout ── */
.gantt-page { font-family: 'Segoe UI', sans-serif; }

.gantt-header-bar {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    color: white; padding: 1.5rem 0; margin-bottom: 1.5rem;
    border-radius: 0 0 20px 20px;
}

/* ── Sidebar panels ── */
.side-panel { border: none; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,.08); }
.side-panel .card-header { border-radius: 12px 12px 0 0 !important; font-weight: 600; }

.member-badge {
    display: inline-block; width: 12px; height: 12px;
    border-radius: 50%; margin-right: 6px; flex-shrink: 0;
}

/* ── Gantt chart ── */
#ganttWrapper {
    overflow-x: auto; border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,.08);
    background: white;
}

#ganttChart {
    min-width: 900px; position: relative;
    user-select: none;
}

/* Header row */
.g-header {
    display: grid; background: #f8f9fa;
    border-bottom: 2px solid #dee2e6;
    font-size: .75rem; font-weight: 700;
    text-transform: uppercase; color: #6c757d;
    position: sticky; top: 0; z-index: 10;
}

.g-cell-label { padding: 8px 12px; border-right: 1px solid #dee2e6; white-space: nowrap; }
.g-cell-timeline { display: flex; overflow: hidden; }

.g-day-head {
    text-align: center; padding: 4px 0; font-size: .65rem;
    border-right: 1px solid #dee2e6; flex-shrink: 0;
    background: #f8f9fa;
}
.g-day-head.weekend { background: #fff3cd; color: #856404; }
.g-day-head.today-col { background: #cfe2ff; color: #0a58ca; }

/* Rows */
.g-row {
    display: grid; border-bottom: 1px solid #f0f0f0;
    min-height: 44px; align-items: center;
    transition: background .15s;
}
.g-row:hover { background: #f8f9fa; }

.g-label {
    padding: 6px 12px; border-right: 1px solid #dee2e6;
    display: flex; align-items: center; gap: 6px;
    font-size: .85rem; font-weight: 500; white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis;
}

.g-timeline { position: relative; display: flex; height: 44px; }

/* Day columns inside the timeline */
.g-day-col {
    flex-shrink: 0; border-right: 1px solid #f0f0f0;
    height: 100%; position: relative;
}
.g-day-col.weekend { background: rgba(255,243,205,.35); }
.g-day-col.today-col { background: rgba(207,226,255,.45); }

/* Vacation overlays */
.vacation-overlay {
    position: absolute; top: 4px; bottom: 4px;
    background: rgba(220, 53, 69, .22);
    border: 1px solid rgba(220, 53, 69, .4);
    border-radius: 3px; pointer-events: none; z-index: 3;
}
.vacation-label {
    position: absolute; top: 50%; transform: translateY(-50%);
    left: 4px; font-size: .6rem; color: #842029;
    white-space: nowrap; pointer-events: none; z-index: 4;
    font-weight: 600;
}

/* Task bars */
.g-task-bar {
    position: absolute; top: 7px; bottom: 7px;
    border-radius: 6px; cursor: pointer;
    display: flex; align-items: center; padding: 0 8px;
    font-size: .72rem; font-weight: 600; color: white;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    z-index: 5; transition: filter .15s, transform .1s;
    box-shadow: 0 2px 6px rgba(0,0,0,.2);
}
.g-task-bar:hover { filter: brightness(1.1); transform: scaleY(1.05); }

/* Progress stripe */
.g-task-bar .progress-fill {
    position: absolute; left: 0; top: 0; bottom: 0;
    background: rgba(255,255,255,.25); border-radius: 6px 0 0 6px;
    pointer-events: none;
}

/* Milestone diamond */
.g-milestone {
    position: absolute; top: 50%; transform: translate(-50%, -50%) rotate(45deg);
    width: 16px; height: 16px; z-index: 5; cursor: pointer;
}

/* Today line */
#todayLine {
    position: absolute; top: 0; bottom: 0; width: 2px;
    background: #0d6efd; z-index: 8; pointer-events: none;
}
#todayLine::after {
    content: 'Сегодня';
    position: absolute; top: 2px; left: 4px;
    font-size: .65rem; color: #0d6efd; white-space: nowrap; font-weight: 700;
}

/* ── Tooltip ── */
#ganttTooltip {
    position: fixed; background: rgba(0,0,0,.85); color: #fff;
    padding: 8px 12px; border-radius: 8px; font-size: .78rem;
    pointer-events: none; z-index: 9999; display: none;
    max-width: 250px; line-height: 1.5;
}

/* ── Modals list items ── */
.list-item-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 6px 10px; border: 1px solid #dee2e6; border-radius: 6px;
    margin-bottom: 6px; font-size: .85rem;
}
.list-item-row .item-info { display: flex; align-items: center; gap: 6px; flex: 1; min-width: 0; }
.list-item-row .item-actions { display: flex; gap: 4px; flex-shrink: 0; }

/* ── Legend ── */
.legend-box { display: inline-block; width: 16px; height: 12px; border-radius: 3px; margin-right: 4px; vertical-align: middle; }
.vacation-legend { background: rgba(220,53,69,.3); border: 1px solid rgba(220,53,69,.5); }
.weekend-legend { background: rgba(255,243,205,.7); border: 1px solid #ffc107; }
.today-legend { background: rgba(13,110,253,.25); border: 1px solid #0d6efd; }

/* ── Range input ── */
.range-row { display: flex; align-items: center; gap: 10px; }
.range-row input[type=range] { flex: 1; }
.range-val { min-width: 36px; text-align: center; font-weight: 600; color: #0d6efd; }
</style>
}

<div class="gantt-page">
    <div class="gantt-header-bar text-center">
        <h1 class="h3 mb-1">📅 Диаграмма Ганта команды</h1>
        <p class="mb-0 text-white-50">Планирование с учётом графика отпусков</p>
    </div>

    <div class="container-fluid px-3">
        <div class="row g-3">

            <!-- ══ LEFT SIDEBAR ══ -->
            <div class="col-lg-3">

                <!-- Team members -->
                <div class="card side-panel mb-3">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <span>👥 Команда</span>
                        <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#memberModal">
                            <i>＋</i> Добавить
                        </button>
                    </div>
                    <div class="card-body p-2" id="memberList">
                        <div class="text-muted text-center small py-2">Загрузка…</div>
                    </div>
                </div>

                <!-- Vacations -->
                <div class="card side-panel mb-3">
                    <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                        <span>🏖️ Отпуска</span>
                        <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#vacationModal">
                            <i>＋</i> Добавить
                        </button>
                    </div>
                    <div class="card-body p-2" id="vacationList">
                        <div class="text-muted text-center small py-2">Загрузка…</div>
                    </div>
                </div>

                <!-- Tasks -->
                <div class="card side-panel">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <span>📌 Задачи</span>
                        <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#taskModal">
                            <i>＋</i> Добавить
                        </button>
                    </div>
                    <div class="card-body p-2" id="taskList">
                        <div class="text-muted text-center small py-2">Загрузка…</div>
                    </div>
                </div>
            </div>

            <!-- ══ GANTT AREA ══ -->
            <div class="col-lg-9">

                <!-- Controls -->
                <div class="card side-panel mb-3">
                    <div class="card-body py-2">
                        <div class="row align-items-center g-2">
                            <div class="col-md-4">
                                <label class="form-label mb-0 small fw-semibold">Диапазон дат:</label>
                                <div class="input-group input-group-sm">
                                    <input type="date" id="rangeStart" class="form-control">
                                    <span class="input-group-text">—</span>
                                    <input type="date" id="rangeEnd" class="form-control">
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label mb-0 small fw-semibold">Масштаб (px/день):</label>
                                <div class="range-row">
                                    <input type="range" id="dayWidthSlider" min="16" max="60" value="28">
                                    <span class="range-val" id="dayWidthVal">28</span>
                                </div>
                            </div>
                            <div class="col-md-5 text-end">
                                <!-- Legend -->
                                <span class="me-3 small"><span class="legend-box vacation-legend"></span>Отпуск</span>
                                <span class="me-3 small"><span class="legend-box weekend-legend"></span>Выходные</span>
                                <span class="me-3 small"><span class="legend-box today-legend"></span>Сегодня</span>
                                <button class="btn btn-sm btn-outline-secondary" id="scrollToToday">Сегодня ▶</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Smart scheduling panel -->
                <div class="card side-panel mb-3 border-warning">
                    <div class="card-header bg-warning">
                        <span class="fw-semibold">⚡ Умное планирование — расчёт даты с учётом отпуска</span>
                    </div>
                    <div class="card-body py-2">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-3">
                                <label class="form-label mb-1 small">Участник</label>
                                <select id="schedMember" class="form-select form-select-sm"></select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label mb-1 small">Дата начала</label>
                                <input type="date" id="schedStart" class="form-control form-control-sm">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label mb-1 small">Рабочих дней</label>
                                <input type="number" id="schedDays" class="form-control form-control-sm" value="5" min="1">
                            </div>
                            <div class="col-md-2">
                                <button class="btn btn-warning btn-sm w-100" id="schedCalc">Рассчитать</button>
                            </div>
                            <div class="col-md-3">
                                <div id="schedResult" class="small"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Chart -->
                <div id="ganttWrapper">
                    <div id="ganttChart">
                        <div class="text-center py-5 text-muted">Загрузка диаграммы…</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Tooltip ── -->
<div id="ganttTooltip"></div>

<!-- ══════════════════════════ MODALS ══════════════════════════ -->

<!-- Member modal -->
<div class="modal fade" id="memberModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="memberModalTitle">Добавить участника</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="memberId">
                <div class="mb-3">
                    <label class="form-label">Имя <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="memberName" placeholder="Иван Иванов">
                </div>
                <div class="mb-3">
                    <label class="form-label">Роль</label>
                    <input type="text" class="form-control" id="memberRole" placeholder="Разработчик, Аналитик…">
                </div>
                <div class="mb-3">
                    <label class="form-label">Цвет</label>
                    <input type="color" class="form-control form-control-color" id="memberColor" value="#4facfe">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button type="button" class="btn btn-primary" id="saveMemberBtn">Сохранить</button>
            </div>
        </div>
    </div>
</div>

<!-- Vacation modal -->
<div class="modal fade" id="vacationModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="vacationModalTitle">Добавить отпуск</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="vacationId">
                <div class="mb-3">
                    <label class="form-label">Участник <span class="text-danger">*</span></label>
                    <select class="form-select" id="vacationMember"></select>
                </div>
                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label">Дата начала <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" id="vacationStart">
                    </div>
                    <div class="col">
                        <label class="form-label">Дата окончания <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" id="vacationEnd">
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Примечание</label>
                    <input type="text" class="form-control" id="vacationNote" placeholder="Ежегодный, больничный…">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button type="button" class="btn btn-danger" id="saveVacationBtn">Сохранить</button>
            </div>
        </div>
    </div>
</div>

<!-- Task modal -->
<div class="modal fade" id="taskModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="taskModalTitle">Добавить задачу</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="taskId">
                <div class="mb-3">
                    <label class="form-label">Название <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="taskTitle" placeholder="Разработка модуля авторизации">
                </div>
                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label">Участник</label>
                        <select class="form-select" id="taskMember">
                            <option value="">— Вся команда —</option>
                        </select>
                    </div>
                    <div class="col">
                        <label class="form-label">Тип</label>
                        <select class="form-select" id="taskType">
                            <option value="task">Задача</option>
                            <option value="sprint">Спринт</option>
                            <option value="milestone">Веха</option>
                        </select>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label">Дата начала <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" id="taskStart">
                    </div>
                    <div class="col">
                        <label class="form-label">Дата окончания <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" id="taskEnd">
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Прогресс: <span id="progressLabel">0</span>%</label>
                    <input type="range" class="form-range" id="taskProgress" min="0" max="100" value="0"
                           oninput="document.getElementById('progressLabel').textContent=this.value">
                </div>
                <div class="mb-3">
                    <label class="form-label">Цвет</label>
                    <input type="color" class="form-control form-control-color" id="taskColor" value="#28a745">
                </div>
                <div class="mb-3">
                    <label class="form-label">Описание</label>
                    <textarea class="form-control" id="taskDesc" rows="2"></textarea>
                </div>

                <!-- Vacation warning block -->
                <div id="taskVacationWarning" class="alert alert-warning d-none">
                    <strong>⚠️ Пересечение с отпуском!</strong>
                    <div id="taskVacationWarnText"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button type="button" class="btn btn-success" id="saveTaskBtn">Сохранить</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ══════════════════════════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════════════════════════
let ganttData = { members: [], vacations: [], tasks: [] };
let DAY_W = 28;   // px per day
let rangeStart, rangeEnd; // Date objects

// ══════════════════════════════════════════════════════════════
//  INIT
// ══════════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', async () => {
    // Default range: current month ± 1 month
    const today = new Date();
    const s = new Date(today.getFullYear(), today.getMonth() - 1, 1);
    const e = new Date(today.getFullYear(), today.getMonth() + 2, 0);
    document.getElementById('rangeStart').value = fmt(s);
    document.getElementById('rangeEnd').value = fmt(e);
    document.getElementById('schedStart').value = fmt(today);

    dayWidthSlider.addEventListener('input', () => {
        DAY_W = +dayWidthSlider.value;
        document.getElementById('dayWidthVal').textContent = DAY_W;
        renderChart();
    });

    document.getElementById('rangeStart').addEventListener('change', renderChart);
    document.getElementById('rangeEnd').addEventListener('change', renderChart);

    document.getElementById('scrollToToday').addEventListener('click', scrollToToday);

    await loadData();

    // Watch task dates for vacation overlap
    ['taskStart','taskEnd','taskMember'].forEach(id =>
        document.getElementById(id).addEventListener('change', checkTaskVacationOverlap));
});

// ══════════════════════════════════════════════════════════════
//  DATA LOADING
// ══════════════════════════════════════════════════════════════
async function loadData() {
    const res = await fetch('/Gantt/Data');
    const json = await res.json();
    if (json.success) {
        ganttData = json.data;
        renderAll();
    }
}

function renderAll() {
    renderMemberList();
    renderVacationList();
    renderTaskList();
    populateMemberSelects();
    renderChart();
}

// ══════════════════════════════════════════════════════════════
//  MEMBER LIST
// ══════════════════════════════════════════════════════════════
function renderMemberList() {
    const el = document.getElementById('memberList');
    if (!ganttData.members.length) {
        el.innerHTML = '<div class="text-muted text-center small py-2">Нет участников</div>';
        return;
    }
    el.innerHTML = ganttData.members.map(m => `
        <div class="list-item-row">
            <div class="item-info">
                <span class="member-badge" style="background:${m.color}"></span>
                <div>
                    <div class="fw-semibold">${esc(m.name)}</div>
                    ${m.role ? `<div class="text-muted" style="font-size:.75rem">${esc(m.role)}</div>` : ''}
                </div>
            </div>
            <div class="item-actions">
                <button class="btn btn-xs btn-outline-primary" style="padding:2px 7px;font-size:.72rem" onclick="editMember('${m.id}')">✎</button>
                <button class="btn btn-xs btn-outline-danger"  style="padding:2px 7px;font-size:.72rem" onclick="deleteMember('${m.id}')">✕</button>
            </div>
        </div>`).join('');
}

// ══════════════════════════════════════════════════════════════
//  VACATION LIST
// ══════════════════════════════════════════════════════════════
function renderVacationList() {
    const el = document.getElementById('vacationList');
    if (!ganttData.vacations.length) {
        el.innerHTML = '<div class="text-muted text-center small py-2">Нет отпусков</div>';
        return;
    }
    // Sort by start date
    const sorted = [...ganttData.vacations].sort((a,b) => new Date(a.startDate) - new Date(b.startDate));
    el.innerHTML = sorted.map(v => {
        const m = ganttData.members.find(x => x.id === v.memberId);
        const name = m ? m.name : '—';
        const color = m ? m.color : '#ccc';
        return `
        <div class="list-item-row">
            <div class="item-info" style="flex-direction:column;align-items:flex-start">
                <div style="display:flex;align-items:center;gap:5px">
                    <span class="member-badge" style="background:${color}"></span>
                    <strong>${esc(name)}</strong>
                </div>
                <div class="text-danger" style="font-size:.75rem">
                    🏖️ ${shortDate(v.startDate)} — ${shortDate(v.endDate)}
                    ${v.note ? `<span class="text-muted">(${esc(v.note)})</span>` : ''}
                </div>
            </div>
            <div class="item-actions">
                <button class="btn btn-xs btn-outline-primary" style="padding:2px 7px;font-size:.72rem" onclick="editVacation('${v.id}')">✎</button>
                <button class="btn btn-xs btn-outline-danger"  style="padding:2px 7px;font-size:.72rem" onclick="deleteVacation('${v.id}')">✕</button>
            </div>
        </div>`;
    }).join('');
}

// ══════════════════════════════════════════════════════════════
//  TASK LIST (sidebar)
// ══════════════════════════════════════════════════════════════
function renderTaskList() {
    const el = document.getElementById('taskList');
    if (!ganttData.tasks.length) {
        el.innerHTML = '<div class="text-muted text-center small py-2">Нет задач</div>';
        return;
    }
    const sorted = [...ganttData.tasks].sort((a,b) => new Date(a.startDate) - new Date(b.startDate));
    el.innerHTML = sorted.map(t => {
        const m = ganttData.members.find(x => x.id === t.memberId);
        return `
        <div class="list-item-row">
            <div class="item-info">
                <span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:${t.color};margin-right:5px;flex-shrink:0"></span>
                <div style="min-width:0">
                    <div class="fw-semibold text-truncate" style="max-width:140px" title="${esc(t.title)}">${esc(t.title)}</div>
                    <div class="text-muted" style="font-size:.72rem">
                        ${m ? esc(m.name) : 'Команда'} · ${shortDate(t.startDate)}
                    </div>
                </div>
            </div>
            <div class="item-actions">
                <button class="btn btn-xs btn-outline-primary" style="padding:2px 7px;font-size:.72rem" onclick="editTask('${t.id}')">✎</button>
                <button class="btn btn-xs btn-outline-danger"  style="padding:2px 7px;font-size:.72rem" onclick="deleteTask('${t.id}')">✕</button>
            </div>
        </div>`;
    }).join('');
}

