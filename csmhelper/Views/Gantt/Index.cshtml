// ══════════════════════════════════════════════════════════════
//  GANTT CHART RENDERING
// ══════════════════════════════════════════════════════════════
function renderChart() {
    rangeStart = parseDate(document.getElementById('rangeStart').value);
    rangeEnd   = parseDate(document.getElementById('rangeEnd').value);
    if (!rangeStart || !rangeEnd || rangeStart >= rangeEnd) return;

    const days = daysBetween(rangeStart, rangeEnd) + 1;
    const labelW = 160; // px
    const totalW = labelW + days * DAY_W;

    const chart = document.getElementById('ganttChart');
    chart.innerHTML = '';
    chart.style.width = totalW + 'px';

    // ── Header ──
    const headerRow = document.createElement('div');
    headerRow.className = 'g-header';
    headerRow.style.gridTemplateColumns = `${labelW}px 1fr`;

    const labelHead = document.createElement('div');
    labelHead.className = 'g-cell-label';
    labelHead.textContent = 'Участник / Задача';
    headerRow.appendChild(labelHead);

    const timelineHead = document.createElement('div');
    timelineHead.className = 'g-cell-timeline';
    timelineHead.style.width = (days * DAY_W) + 'px';

    const today = new Date(); today.setHours(0,0,0,0);
    for (let i = 0; i < days; i++) {
        const d = addDays(rangeStart, i);
        const isWE = d.getDay() === 0 || d.getDay() === 6;
        const isToday = d.getTime() === today.getTime();
        const cell = document.createElement('div');
        cell.className = 'g-day-head' + (isWE ? ' weekend' : '') + (isToday ? ' today-col' : '');
        cell.style.width = DAY_W + 'px';
        // Show day number; on 1st of month also show month
        const label = d.getDate() === 1
            ? d.toLocaleDateString('ru-RU', {month:'short', day:'numeric'})
            : d.getDate();
        cell.textContent = label;
        timelineHead.appendChild(cell);
    }
    headerRow.appendChild(timelineHead);
    chart.appendChild(headerRow);

    // ── Today line container (positioned on top of rows) ──
    const todayWrapper = document.createElement('div');
    todayWrapper.style.cssText = 'position:relative;';

    // ── Rows: one per member + their tasks ──
    // Group tasks by member; also tasks with no member go to a "team" group
    const membersToShow = [...ganttData.members];
    if (ganttData.tasks.some(t => !t.memberId)) {
        membersToShow.push({ id: '', name: '— Вся команда —', color: '#6c757d', role: '' });
    }

    membersToShow.forEach(member => {
        const memberTasks = ganttData.tasks.filter(t => t.memberId === member.id);
        const memberVacations = ganttData.vacations.filter(v => v.memberId === member.id);

        if (memberTasks.length === 0 && memberVacations.length === 0 && member.id === '') return;

        // ── Member label row ──
        const memberRow = document.createElement('div');
        memberRow.className = 'g-row';
        memberRow.style.gridTemplateColumns = `${labelW}px 1fr`;
        memberRow.style.background = '#f0f4ff';

        const mLabel = document.createElement('div');
        mLabel.className = 'g-label';
        mLabel.innerHTML = `<span class="member-badge" style="background:${member.color}"></span><span>${esc(member.name)}</span>`;
        if (member.role) mLabel.title = member.role;
        memberRow.appendChild(mLabel);

        // Vacation timeline for member row
        const mTimeline = buildTimelineCells(days, today, memberVacations, member.color, labelW);
        memberRow.appendChild(mTimeline);
        chart.appendChild(memberRow);

        // ── Task rows ──
        memberTasks.forEach(task => {
            const taskRow = document.createElement('div');
            taskRow.className = 'g-row';
            taskRow.style.gridTemplateColumns = `${labelW}px 1fr`;

            const tLabel = document.createElement('div');
            tLabel.className = 'g-label';
            tLabel.style.paddingLeft = '24px';
            const typeIcon = task.type === 'sprint' ? '⚡' : task.type === 'milestone' ? '🔷' : '▪';
            tLabel.innerHTML = `<span style="color:${task.color}">${typeIcon}</span><span style="font-size:.8rem">${esc(task.title)}</span>`;
            taskRow.appendChild(tLabel);

            const tTimeline = buildTimelineCells(days, today, memberVacations, member.color, labelW);

            // Draw task bar
            const taskStart = parseDate(task.startDate);
            const taskEnd   = parseDate(task.endDate);
            if (taskStart && taskEnd) {
                const startOffset = daysBetween(rangeStart, taskStart);
                const endOffset   = daysBetween(rangeStart, taskEnd);
                if (endOffset >= 0 && startOffset <= days) {
                    const left = Math.max(0, startOffset) * DAY_W;
                    const right = Math.min(days, endOffset + 1) * DAY_W;
                    const width = right - left;

                    if (task.type === 'milestone') {
                        const diamond = document.createElement('div');
                        diamond.className = 'g-milestone';
                        diamond.style.cssText = `left:${left + DAY_W/2}px;background:${task.color};`;
                        addTaskTooltip(diamond, task, member, memberVacations);
                        tTimeline.appendChild(diamond);
                    } else {
                        const bar = document.createElement('div');
                        bar.className = 'g-task-bar';
                        bar.style.cssText = `left:${left}px;width:${width}px;background:${task.color};`;
                        bar.innerHTML = `
                            <div class="progress-fill" style="width:${task.progress}%"></div>
                            <span style="position:relative;z-index:1">${esc(task.title)}</span>
                        `;
                        addTaskTooltip(bar, task, member, memberVacations);
                        bar.addEventListener('click', () => editTask(task.id));
                        tTimeline.appendChild(bar);
                    }
                }
            }
            taskRow.appendChild(tTimeline);
            chart.appendChild(taskRow);
        });
    });

    // ── Today vertical line ──
    const todayOffset = daysBetween(rangeStart, today);
    if (todayOffset >= 0 && todayOffset <= days) {
        const tl = document.createElement('div');
        tl.id = 'todayLine';
        tl.style.left = (labelW + todayOffset * DAY_W + DAY_W/2) + 'px';
        tl.style.top = '0';
        tl.style.height = chart.scrollHeight + 'px';
        // We'll add it after chart is built
        chart.style.position = 'relative';
        chart.appendChild(tl);
    }
}

function buildTimelineCells(days, today, vacations, memberColor, labelW) {
    const timeline = document.createElement('div');
    timeline.className = 'g-timeline';
    timeline.style.width = (days * DAY_W) + 'px';
    timeline.style.position = 'relative';

    for (let i = 0; i < days; i++) {
        const d = addDays(rangeStart, i);
        const isWE = d.getDay() === 0 || d.getDay() === 6;
        const isToday = d.getTime() === today.getTime();
        const cell = document.createElement('div');
        cell.className = 'g-day-col' + (isWE ? ' weekend' : '') + (isToday ? ' today-col' : '');
        cell.style.width = DAY_W + 'px';
        timeline.appendChild(cell);
    }

    // Draw vacation overlays
    vacations.forEach(v => {
        const vStart = parseDate(v.startDate);
        const vEnd   = parseDate(v.endDate);
        if (!vStart || !vEnd) return;
        const startOff = daysBetween(rangeStart, vStart);
        const endOff   = daysBetween(rangeStart, vEnd);
        if (endOff < 0 || startOff > days) return;

        const left  = Math.max(0, startOff) * DAY_W;
        const right = Math.min(days, endOff + 1) * DAY_W;
        const width = right - left;

        const overlay = document.createElement('div');
        overlay.className = 'vacation-overlay';
        overlay.style.left  = left + 'px';
        overlay.style.width = width + 'px';
        overlay.title = `🏖️ Отпуск: ${shortDate(v.startDate)} — ${shortDate(v.endDate)}${v.note ? '\n' + v.note : ''}`;

        // Label if enough space
        if (width > 30) {
            const lbl = document.createElement('div');
            lbl.className = 'vacation-label';
            lbl.textContent = '🏖️';
            overlay.appendChild(lbl);
        }
        timeline.appendChild(overlay);
    });

    return timeline;
}

function addTaskTooltip(el, task, member, memberVacations) {
    const tooltip = document.getElementById('ganttTooltip');
    el.addEventListener('mouseenter', e => {
        const vOverlaps = memberVacations.filter(v => {
            const vs = parseDate(v.startDate), ve = parseDate(v.endDate);
            const ts = parseDate(task.startDate), te = parseDate(task.endDate);
            return vs && ve && ts && te && vs <= te && ve >= ts;
        });
        let html = `<strong>${esc(task.title)}</strong><br>`;
        html += `👤 ${esc(member.name)}<br>`;
        html += `📅 ${shortDate(task.startDate)} — ${shortDate(task.endDate)}<br>`;
        html += `📊 Прогресс: ${task.progress}%`;
        if (task.description) html += `<br><em>${esc(task.description)}</em>`;
        if (vOverlaps.length) {
            html += `<br><span style="color:#ff6b6b">⚠️ Пересекается с отпуском!</span>`;
        }
        tooltip.innerHTML = html;
        tooltip.style.display = 'block';
        moveTooltip(e);
    });
    el.addEventListener('mousemove', moveTooltip);
    el.addEventListener('mouseleave', () => { tooltip.style.display = 'none'; });
}

function moveTooltip(e) {
    const t = document.getElementById('ganttTooltip');
    t.style.left = (e.clientX + 14) + 'px';
    t.style.top  = (e.clientY + 14) + 'px';
}

function scrollToToday() {
    const today = new Date(); today.setHours(0,0,0,0);
    const off = daysBetween(rangeStart, today);
    const wrapper = document.getElementById('ganttWrapper');
    const labelW = 160;
    wrapper.scrollLeft = labelW + off * DAY_W - wrapper.clientWidth / 2;
}

