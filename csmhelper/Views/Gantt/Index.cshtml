function checkTaskVacationOverlap() {
    const memberId = document.getElementById('taskMember').value;
    const start    = document.getElementById('taskStart').value;
    const end      = document.getElementById('taskEnd').value;
    const warn     = document.getElementById('taskVacationWarning');
    const warnText = document.getElementById('taskVacationWarnText');

    if (!memberId || !start || !end) { warn.classList.add('d-none'); return; }

    const ts = parseDate(start), te = parseDate(end);
    const overlapping = ganttData.vacations.filter(v => {
        if (v.memberId !== memberId) return false;
        const vs = parseDate(v.startDate), ve = parseDate(v.endDate);
        return vs && ve && vs <= te && ve >= ts;
    });

    if (overlapping.length) {
        const member = ganttData.members.find(m => m.id === memberId);
        warnText.innerHTML = overlapping.map(v =>
            `Участник <strong>${esc(member?.name || '')}</strong> в отпуске с <strong>${shortDate(v.startDate)}</strong> по <strong>${shortDate(v.endDate)}</strong>${v.note ? ' (' + esc(v.note) + ')' : ''}.`
        ).join('<br>');
        warn.classList.remove('d-none');
    } else {
        warn.classList.add('d-none');
    }
}

