@{
    ViewData["Title"] = "Диаграмма Ганта";
    Layout = "_Layout";
}

@section Styles {
<style>
    :root {
        --primary: #1b6ec2;
        --primary-dark: #1861ac;
        --primary-light: #e8f0fb;
        --border: #e5e5e5;
        --shadow: 0 .25rem .75rem rgba(0,0,0,.08);
        --radius: 6px;
    }

    .page-header {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color: #fff;
        padding: 1.5rem 0 1.25rem;
        margin: -1rem -15px 1.5rem;
        box-shadow: var(--shadow);
    }
    .page-header h2 { font-size: 1.5rem; font-weight: 600; margin: 0; }
    .page-header p  { margin: .25rem 0 0; opacity: .85; font-size: .9rem; }

    .card { border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); }
    .card-header {
        background: var(--primary-light);
        border-bottom: 1px solid #c9d9ef;
        font-weight: 600;
        color: var(--primary-dark);
        padding: .65rem 1rem;
        display: flex; align-items: center; gap: .4rem;
    }

    .btn-primary { background-color: var(--primary); border-color: var(--primary-dark); }
    .btn-primary:hover { background-color: var(--primary-dark); }

    /* Employee card */
    .emp-card {
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: .75rem .875rem;
        background: #fafbfc;
        position: relative;
    }
    .emp-card .remove-btn {
        position: absolute; top: .45rem; right: .6rem;
        background: none; border: none; color: #aaa; cursor: pointer; font-size: .95rem;
    }
    .emp-card .remove-btn:hover { color: #dc3545; }

    /* Stats */
    .stat-box {
        background: #fff; border: 1px solid var(--border);
        border-radius: var(--radius); padding: .75rem 1rem; text-align: center;
    }
    .stat-box .val { font-size: 1.5rem; font-weight: 700; color: var(--primary); }
    .stat-box .lbl { font-size: .73rem; color: #6c757d; margin-top: .1rem; }

    /* Utilization bar */
    .util-wrap { background: #eef2f7; border-radius: 4px; height: 7px; margin-top: 3px; overflow: hidden; }
    .util-fill { background: var(--primary); height: 100%; border-radius: 4px; transition: width .4s; }

    /* Gantt SVG */
    #ganttSvg { width: 100%; overflow-x: auto; border: 1px solid var(--border); border-radius: var(--radius); }

    /* Tasks table */
    .table th { background: var(--primary-light); color: var(--primary-dark); font-weight: 600; font-size: .8rem; white-space: nowrap; }
    .table td { font-size: .82rem; vertical-align: middle; }
    .badge-cp { background: #dc3545; color: #fff; font-size: .67rem; padding: .18em .4em; border-radius: 3px; }

    .type-badge { font-size: .7rem; padding: .18em .45em; border-radius: 3px; font-weight: 600; }
    .type-TEST     { background: #fde8e8; color: #b91c1c; }
    .type-DEVBACK  { background: #e3f2fd; color: #0d47a1; }
    .type-DEVFRONT { background: #fff3e0; color: #bf360c; }
    .type-SA       { background: #e8f5e9; color: #1b5e20; }

    /* Loading */
    #overlay {
        display: none; position: fixed; inset: 0;
        background: rgba(255,255,255,.75); z-index: 9999;
        align-items: center; justify-content: center; flex-direction: column; gap: .75rem;
    }
    #overlay.on { display: flex; }
    .spin { width: 48px; height: 48px; border: 4px solid #dde4ee; border-top-color: var(--primary); border-radius: 50%; animation: spin .75s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* SP hint */
    .sp-hint { background: #f0f6ff; border-radius: 4px; font-size: .77rem; color: #374151; padding: .4rem .6rem; }

    /* Vacation rows */
    .vac-row {
        display: flex; gap: .35rem; align-items: center;
        background: #fff5f5; border: 1px solid #f5c2c7;
        border-radius: 4px; padding: .25rem .4rem; margin-top: .35rem;
        font-size: .78rem;
    }
    .vac-row input[type=date] { font-size: .77rem; padding: .1rem .3rem; height: auto; }
    .vac-row .vac-rm { background:none;border:none;color:#aaa;cursor:pointer;font-size:.9rem;padding:0 .2rem; }
    .vac-row .vac-rm:hover { color:#dc3545; }
    .vac-add { font-size: .78rem; color: #b91c1c; cursor: pointer; display: inline-block; margin-top: .25rem; }
    .vac-add:hover { text-decoration: underline; }
</style>
}

<!-- Loading overlay -->
<div id="overlay">
    <div class="spin"></div>
    <div style="color:var(--primary);font-weight:600">Формирование расписания…</div>
    <div id="loadStep" style="font-size:.82rem;color:#6c757d">Подключение к Jira</div>
</div>

<div class="page-header">
    <div class="container">
        <h2>📊 Диаграмма Ганта</h2>
        <p>Автоматическое расписание из задач Jira с учётом ролей и зависимостей</p>
    </div>
</div>

<div id="alertBox" class="mb-3" style="display:none">
    <div class="alert alert-danger alert-dismissible fade show mb-0">
        <span id="alertText"></span>
        <button type="button" class="btn-close" onclick="hideAlert()"></button>
    </div>
</div>

<div class="row g-3">

    <!-- ── LEFT: Config ─────────────────────────────────── -->
    <div class="col-lg-5">

        <!-- Jira -->
        <div class="card mb-3">
            <div class="card-header">🔌 Подключение к Jira</div>
            <div class="card-body">
                <div class="mb-2">
                    <label class="form-label small fw-semibold mb-1">Сервер</label>
                    <input id="jiraServer" type="text" class="form-control form-control-sm"
                           value="https://jira.moscow.alfaintra.net" />
                </div>
                <div class="mb-2">
                    <label class="form-label small fw-semibold mb-1">Проекты (через запятую)</label>
                    <input id="jiraProjects" type="text" class="form-control form-control-sm"
                           value="DKANBAN" placeholder="PROJ1, PROJ2" />
                </div>
                <div class="form-check form-switch mt-1">
                    <input class="form-check-input" type="checkbox" id="verifySsl" />
                    <label class="form-check-label small" for="verifySsl">Проверять SSL-сертификат</label>
                </div>
                <div class="mt-2 p-2 rounded" style="background:#fff8e1;font-size:.77rem;color:#6d4c00;">
                    ℹ️ Для авторизации используются данные текущей сессии Jira
                </div>
            </div>
        </div>

        <!-- Schedule settings -->
        <div class="card mb-3">
            <div class="card-header">⚙️ Параметры планирования</div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-6">
                        <label class="form-label small fw-semibold mb-1">SP в спринте</label>
                        <input id="spBase" type="number" class="form-control form-control-sm" value="21" min="1" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small fw-semibold mb-1">Часов в спринте</label>
                        <input id="sprintHours" type="number" class="form-control form-control-sm" value="80" min="1" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small fw-semibold mb-1">% на Agile-встречи</label>
                        <input id="agilePercent" type="number" class="form-control form-control-sm" value="15" min="0" max="100" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small fw-semibold mb-1">Лаг между задачами (мин)</label>
                        <input id="lagMinutes" type="number" class="form-control form-control-sm" value="60" min="0" />
                    </div>
                </div>
                <div class="sp-hint mt-2">
                    1 SP = <strong id="spH">3.24</strong> ч чистой работы
                    (<strong id="spD">0.48</strong> рабочих дней)
                </div>
            </div>
        </div>

        <!-- Employees -->
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>👥 Сотрудники</span>
                <button class="btn btn-sm btn-outline-primary py-0 px-2" onclick="addEmp()">+ Добавить</button>
            </div>
            <div class="card-body">
                <div id="empList" class="d-flex flex-column gap-2"></div>
            </div>
        </div>

        <button class="btn btn-primary w-100 py-2 fw-semibold" onclick="generate()">
            ▶ Построить диаграмму
        </button>
    </div>

    <!-- ── RIGHT: Results ───────────────────────────────── -->
    <div class="col-lg-7">

        <!-- Stats -->
        <div id="statsSection" style="display:none" class="mb-3">
            <div class="row g-2 mb-3" id="statsCards"></div>

            <div class="card mb-3">
                <div class="card-header">📈 Загрузка ресурсов</div>
                <div class="card-body" id="utilBody"></div>
            </div>
        </div>

        <!-- Gantt SVG chart -->
        <div id="ganttCard" style="display:none" class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>📅 Диаграмма Ганта</span>
                <button class="btn btn-sm btn-outline-primary py-0 px-2" onclick="downloadSvg()">
                    ⬇ SVG
                </button>
            </div>
            <div class="card-body p-2" style="overflow-x:auto">
                <div id="ganttSvgContainer"></div>
            </div>
        </div>

        <!-- Tasks table -->
        <div id="tasksCard" style="display:none" class="card">
            <div class="card-header">📋 Расписание задач</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Задача</th><th>Тип</th><th>SP</th>
                                <th>Начало</th><th>Конец</th><th>Дни</th><th>Исполнитель</th>
                            </tr>
                        </thead>
                        <tbody id="tasksBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ─── Defaults ────────────────────────────────────────────────────
const DEFAULT_EMPLOYEES = [
    { name: 'Венчиков Дмитрий Андреевич',    role: 'analyst' },
    { name: 'Бородин Алексей Александрович', role: 'backend_dev' },
    { name: 'Фещун Игорь Андреевич',         role: 'frontend_dev' },
    { name: 'Самохина Лилия Александровна',  role: 'tester' },
];

const ROLES = [
    { value: 'analyst',      label: 'Аналитик' },
    { value: 'backend_dev',  label: 'Backend разработчик' },
    { value: 'frontend_dev', label: 'Frontend разработчик' },
    { value: 'tester',       label: 'Тестировщик' },
];

// Role → color for Gantt bars
const ROLE_COLORS = {
    analyst:      '#96CEB4',
    backend_dev:  '#4ECDC4',
    frontend_dev: '#45B7D1',
    tester:       '#FF6B6B',
};

let empCount = 0;

document.addEventListener('DOMContentLoaded', () => {
    DEFAULT_EMPLOYEES.forEach(e => addEmp(e.name, e.role));
    ['spBase','sprintHours','agilePercent'].forEach(id =>
        document.getElementById(id).addEventListener('input', updateSpCalc));
    updateSpCalc();
});

function updateSpCalc() {
    const base  = +document.getElementById('spBase').value || 21;
    const hours = +document.getElementById('sprintHours').value || 80;
    const agile = +document.getElementById('agilePercent').value || 15;
    const h = hours * (1 - agile / 100) / base;
    document.getElementById('spH').textContent = h.toFixed(2);
    document.getElementById('spD').textContent = (h / 8).toFixed(2);
}

// ─── Employees ───────────────────────────────────────────────────
function addEmp(name = '', role = 'backend_dev') {
    const id = ++empCount;
    const opts = ROLES.map(r =>
        `<option value="${r.value}" ${r.value === role ? 'selected' : ''}>${r.label}</option>`
    ).join('');

    document.getElementById('empList').insertAdjacentHTML('beforeend', `
    <div class="emp-card" id="emp-${id}">
      <button class="remove-btn" onclick="document.getElementById('emp-${id}').remove()" title="Удалить">✕</button>
      <div class="row g-2 align-items-center">
        <div class="col-12 col-sm-5">
          <label class="form-label small mb-1">ФИО</label>
          <input type="text" class="form-control form-control-sm ename" value="${name}" placeholder="Иванов Иван" />
        </div>
        <div class="col-8 col-sm-4">
          <label class="form-label small mb-1">Роль</label>
          <select class="form-select form-select-sm erole">${opts}</select>
        </div>
        <div class="col-4 col-sm-3">
          <label class="form-label small mb-1">Ч/день</label>
          <input type="number" class="form-control form-control-sm ehours" value="8" min="1" max="24" />
        </div>
      </div>
      <div class="mt-1">
        <a class="small text-primary me-3" style="cursor:pointer" onclick="toggleSched(${id})">
          🕐 Рабочее время
        </a>
        <a class="small" style="cursor:pointer;color:#b91c1c" onclick="toggleVac(${id})">
          🏖️ Отпуска <span id="vac-count-${id}" class="text-muted">(0)</span>
        </a>
        <div id="sched-${id}" style="display:none" class="row g-2 mt-1">
          <div class="col-6 col-sm-3"><label class="form-label small mb-1">Начало</label>
            <input type="time" class="form-control form-control-sm ews" value="09:00" /></div>
          <div class="col-6 col-sm-3"><label class="form-label small mb-1">Конец</label>
            <input type="time" class="form-control form-control-sm ewe" value="18:00" /></div>
          <div class="col-6 col-sm-3"><label class="form-label small mb-1">Обед с</label>
            <input type="time" class="form-control form-control-sm els" value="13:00" /></div>
          <div class="col-6 col-sm-3"><label class="form-label small mb-1">Обед до</label>
            <input type="time" class="form-control form-control-sm ele" value="14:00" /></div>
        </div>
        <div id="vac-${id}" style="display:none" class="mt-1">
          <div class="vac-list" data-emp="${id}"></div>
          <span class="vac-add" onclick="addVac(${id})">+ Добавить отпуск</span>
        </div>
      </div>
    </div>`);
}

// ─── Vacations per employee ──────────────────────────────────────
function toggleVac(id) {
    const el = document.getElementById(`vac-${id}`);
    el.style.display = el.style.display === 'none' ? '' : 'none';
}

function addVac(id, start = '', end = '') {
    const list = document.querySelector(`#vac-${id} .vac-list`);
    if (!list) return;
    const row = document.createElement('div');
    row.className = 'vac-row';
    row.innerHTML = `
        <span>с</span>
        <input type="date" class="form-control form-control-sm vac-start" value="${start}">
        <span>по</span>
        <input type="date" class="form-control form-control-sm vac-end" value="${end}">
        <input type="text" class="form-control form-control-sm vac-note flex-grow-1" placeholder="примечание" style="font-size:.77rem">
        <button class="vac-rm" type="button" title="Удалить" onclick="this.parentElement.remove();updateVacCount(${id})">✕</button>
    `;
    list.appendChild(row);
    updateVacCount(id);
}

function updateVacCount(id) {
    const cnt = document.querySelectorAll(`#vac-${id} .vac-row`).length;
    const lbl = document.getElementById(`vac-count-${id}`);
    if (lbl) lbl.textContent = `(${cnt})`;
}

function getEmployeeVacations(empCard) {
    return [...empCard.querySelectorAll('.vac-row')].map(r => ({
        startDate: r.querySelector('.vac-start').value,
        endDate:   r.querySelector('.vac-end').value,
        note:      r.querySelector('.vac-note').value.trim(),
    })).filter(v => v.startDate && v.endDate);
}

function toggleSched(id) {
    const el = document.getElementById(`sched-${id}`);
    el.style.display = el.style.display === 'none' ? '' : 'none';
}

function getEmployees() {
    return [...document.querySelectorAll('#empList .emp-card')].map(c => ({
        name:         c.querySelector('.ename').value.trim(),
        role:         c.querySelector('.erole').value,
        hoursPerDay:  +c.querySelector('.ehours').value || 8,
        workStart:    c.querySelector('.ews').value || '09:00',
        workEnd:      c.querySelector('.ewe').value || '18:00',
        lunchStart:   c.querySelector('.els').value || '13:00',
        lunchEnd:     c.querySelector('.ele').value || '14:00',
        vacations:    getEmployeeVacations(c),
    })).filter(e => e.name);
}

// Карта «имя сотрудника → массив отпусков» для отрисовки на SVG.
function buildVacationMap() {
    const map = {};
    [...document.querySelectorAll('#empList .emp-card')].forEach(c => {
        const name = c.querySelector('.ename').value.trim();
        if (!name) return;
        map[name] = getEmployeeVacations(c)
            .map(v => ({ start: new Date(v.startDate), end: new Date(v.endDate), note: v.note }))
            .filter(v => !isNaN(v.start) && !isNaN(v.end));
    });
    return map;
}

// ─── Generate ────────────────────────────────────────────────────
async function generate() {
    hideAlert();
    const employees = getEmployees();
    if (!employees.length) { showAlert('Добавьте хотя бы одного сотрудника.'); return; }

    const projects = document.getElementById('jiraProjects').value
        .split(',').map(p => p.trim()).filter(Boolean);
    if (!projects.length) { showAlert('Укажите хотя бы один проект.'); return; }

    const payload = {
        jiraServer: document.getElementById('jiraServer').value.trim(),
        projects,
        verifySsl: document.getElementById('verifySsl').checked,
        employees,
        schedule: {
            spBase:                   +document.getElementById('spBase').value || 21,
            sprintHoursTotal:         +document.getElementById('sprintHours').value || 80,
            agilePercent:             +document.getElementById('agilePercent').value || 15,
            taskTransitionLagMinutes: +document.getElementById('lagMinutes').value || 60,
        }
    };

    showLoading('Подключение к Jira…');

    try {
        const res = await fetch('/Gant/Generate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        setLoadStep('Рендеринг диаграммы…');
        const data = await res.json();
        hideLoading();
        if (!data.success) { showAlert(data.error || 'Неизвестная ошибка'); return; }
        renderResults(data);
    } catch(e) {
        hideLoading();
        showAlert('Ошибка: ' + e.message);
    }
}

// ─── Render ───────────────────────────────────────────────────────
function renderResults(data) {
    const { stats, scheduled, criticalPathKeys, utilization } = data;
    const cpSet = new Set(criticalPathKeys || []);

    // Stats cards
    document.getElementById('statsCards').innerHTML = [
        { v: stats.scheduledTasks,                          l: 'Задач' },
        { v: stats.totalStoryPoints,                        l: 'Story Points' },
        { v: (stats.totalWorkHours || 0).toFixed(1) + ' ч', l: 'Часов работы' },
        { v: fmtDate(stats.completionDate),                 l: 'Завершение' },
    ].map(s => `
        <div class="col-6 col-sm-3">
          <div class="stat-box">
            <div class="val">${s.v ?? '—'}</div>
            <div class="lbl">${s.l}</div>
          </div>
        </div>`).join('');

    // Utilization
    const maxH = Math.max(...Object.values(utilization || {}), 1);
    document.getElementById('utilBody').innerHTML = Object.entries(utilization || {})
        .map(([name, h]) => `
        <div class="mb-2">
          <div class="d-flex justify-content-between small">
            <span class="fw-semibold">${name}</span>
            <span class="text-muted">${h.toFixed(1)} ч (${(h/8).toFixed(1)} дн)</span>
          </div>
          <div class="util-wrap"><div class="util-fill" style="width:${Math.round(h/maxH*100)}%"></div></div>
        </div>`).join('') || '<p class="text-muted small mb-0">Нет данных</p>';

    document.getElementById('statsSection').style.display = '';

    // Gantt SVG
    if (scheduled.length) {
        const svg = buildGanttSvg(scheduled, cpSet);
        document.getElementById('ganttSvgContainer').innerHTML = svg;
        document.getElementById('ganttCard').style.display = '';
    }

    // Tasks table
    const typeLabel = t => {
        const map = { 'TEST':'type-TEST TEST','DEV BACK':'type-DEVBACK BACK','DEV FRONT':'type-DEVFRONT FRONT','SA':'type-SA SA' };
        const [cls, txt] = (map[t] || `type-SA ${t}`).split(' ');
        return `<span class="type-badge ${cls}">${txt}</span>`;
    };

    document.getElementById('tasksBody').innerHTML = scheduled.map(t => {
        const cp = cpSet.has(t.key) ? ' <span class="badge-cp">КП</span>' : '';
        return `<tr ${cpSet.has(t.key) ? 'style="background:#fff5f5"' : ''}>
          <td><a href="${t.link}" target="_blank" class="fw-semibold text-primary">${t.key}</a>${cp}</td>
          <td>${typeLabel(t.taskType)}</td>
          <td>${t.storyPoints}</td>
          <td class="text-muted">${fmtDt(t.scheduledStart)}</td>
          <td class="text-muted">${fmtDt(t.scheduledEnd)}</td>
          <td>${(t.durationWorkDays||0).toFixed(1)}</td>
          <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
              title="${t.assignedResource||''}">${t.assignedResource||'—'}</td>
        </tr>`;
    }).join('');

    document.getElementById('tasksCard').style.display = '';
    document.getElementById('statsSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// ─── Gantt SVG renderer ──────────────────────────────────────────
function buildGanttSvg(tasks, cpSet) {
    const ROW_H   = 34;
    const LABEL_W = 90;
    const PADDING = 10;
    const HEADER  = 30;
    const ROLE_BY_NAME = buildRoleMap();
    const VAC_BY_NAME  = buildVacationMap();

    if (!tasks.length) return '';

    // Расширяем диапазон, чтобы захватить отпуска, попадающие в окно задач
    const dates = tasks.flatMap(t => [new Date(t.scheduledStart), new Date(t.scheduledEnd)]);
    let minDate = new Date(Math.min(...dates));
    let maxDate = new Date(Math.max(...dates));
    Object.values(VAC_BY_NAME).flat().forEach(v => {
        if (v.end < minDate || v.start > maxDate) return; // отпуск вне видимого окна — не растягиваем
        if (v.start < minDate) minDate = new Date(v.start);
        if (v.end > maxDate) maxDate = new Date(v.end);
    });
    const totalMs  = maxDate - minDate;

    const CHART_W = Math.max(600, tasks.length * 30);
    const HEIGHT  = HEADER + tasks.length * ROW_H + PADDING;

    function x(dt) {
        return LABEL_W + ((new Date(dt) - minDate) / totalMs) * CHART_W;
    }

    const lines = [];

    // Background
    lines.push(`<rect width="${LABEL_W + CHART_W}" height="${HEIGHT}" fill="#fff"/>`);

    // Header date ticks
    const dayMs = 86400000;
    let tickDate = new Date(minDate);
    tickDate.setHours(0,0,0,0);
    while (tickDate <= maxDate) {
        const tx = x(tickDate);
        if (tx >= LABEL_W) {
            const label = tickDate.toLocaleDateString('ru-RU', { day: '2-digit', month: '2-digit' });
            lines.push(`<line x1="${tx}" y1="0" x2="${tx}" y2="${HEIGHT}" stroke="#e5e5e5" stroke-width="1"/>`);
            lines.push(`<text x="${tx+2}" y="14" font-size="9" fill="#999">${label}</text>`);
        }
        tickDate = new Date(tickDate.getTime() + dayMs);
    }

    // Rows
    tasks.forEach((t, i) => {
        const y  = HEADER + i * ROW_H;
        const x1 = x(t.scheduledStart);
        const x2 = x(t.scheduledEnd);
        const bw = Math.max(x2 - x1, 4);

        const isCp   = cpSet.has(t.key);
        const role   = ROLE_BY_NAME[t.assignedResource] || 'backend_dev';
        const color  = isCp ? '#dc3545' : (ROLE_COLORS[role] || '#95A5A6');

        // Row bg
        lines.push(`<rect x="0" y="${y}" width="${LABEL_W + CHART_W}" height="${ROW_H}" fill="${i%2===0?'#fafbfc':'#fff'}"/>`);

        // Vacation overlays for this task's assignee — отрисовываются под баром задачи
        const vacs = VAC_BY_NAME[t.assignedResource] || [];
        vacs.forEach(v => {
            if (v.end < minDate || v.start > maxDate) return;
            const vs = v.start < minDate ? minDate : v.start;
            // Конец отпуска включительный — растягиваем до конца этого дня
            const veInclusive = new Date(v.end);
            veInclusive.setHours(23, 59, 59, 999);
            const ve = veInclusive > maxDate ? maxDate : veInclusive;
            const vx1 = x(vs);
            const vx2 = x(ve);
            const vw  = Math.max(vx2 - vx1, 2);
            lines.push(`<rect x="${vx1}" y="${y+2}" width="${vw}" height="${ROW_H-4}" fill="#dc3545" opacity="0.18"/>`);
            lines.push(`<rect x="${vx1}" y="${y+2}" width="${vw}" height="${ROW_H-4}" fill="none" stroke="#dc3545" stroke-width="0.5" stroke-dasharray="3,2" opacity="0.5"><title>🏖️ Отпуск ${vs.toLocaleDateString('ru-RU')} — ${v.end.toLocaleDateString('ru-RU')}${v.note?': '+v.note:''}</title></rect>`);
        });

        // Task key label
        lines.push(`<text x="${LABEL_W - 4}" y="${y + ROW_H/2 + 4}" font-size="10" fill="#374151" text-anchor="end" font-weight="${isCp?'bold':'normal'}">${t.key}</text>`);

        // Bar
        lines.push(`<rect x="${x1}" y="${y+5}" width="${bw}" height="${ROW_H-10}" rx="3" fill="${color}" opacity="0.85"/>`);

        // Bar label
        if (bw > 30) {
            lines.push(`<text x="${x1 + bw/2}" y="${y + ROW_H/2 + 4}" font-size="9" fill="#fff" text-anchor="middle" font-weight="600">${t.storyPoints}SP</text>`);
        }

        // Due date marker
        if (t.dueDate) {
            const dx = x(t.dueDate);
            lines.push(`<polygon points="${dx},${y+3} ${dx-4},${y+12} ${dx+4},${y+12}" fill="#dc3545" opacity="0.7"/>`);
        }

        // Dependency arrows
        (t.blockedBy || []).forEach(bk => {
            const blocker = tasks.find(tt => tt.key === bk);
            if (!blocker) return;
            const bj = tasks.indexOf(blocker);
            const ax1 = x(blocker.scheduledEnd);
            const ay1 = HEADER + bj * ROW_H + ROW_H / 2;
            const ax2 = x1;
            const ay2 = y + ROW_H / 2;
            lines.push(`<path d="M${ax1},${ay1} C${ax1+20},${ay1} ${ax2-20},${ay2} ${ax2},${ay2}" fill="none" stroke="#aaa" stroke-width="1" marker-end="url(#arr)" opacity="0.6"/>`);
        });
    });

    const W = LABEL_W + CHART_W;
    return `<svg xmlns="http://www.w3.org/2000/svg" width="${W}" height="${HEIGHT}" viewBox="0 0 ${W} ${HEIGHT}">
  <defs>
    <marker id="arr" markerWidth="6" markerHeight="6" refX="3" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill="#aaa"/>
    </marker>
  </defs>
  ${lines.join('\n  ')}
</svg>`;
}

function buildRoleMap() {
    const map = {};
    [...document.querySelectorAll('#empList .emp-card')].forEach(c => {
        const name = c.querySelector('.ename').value.trim();
        const role = c.querySelector('.erole').value;
        if (name) map[name] = role;
    });
    return map;
}

function downloadSvg() {
    const svg = document.getElementById('ganttSvgContainer').innerHTML;
    if (!svg) return;
    const blob = new Blob([svg], { type: 'image/svg+xml' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'gantt.svg';
    a.click();
}

// ─── Helpers ─────────────────────────────────────────────────────
function fmtDate(iso) {
    if (!iso) return '—';
    return new Date(iso).toLocaleDateString('ru-RU', { day:'2-digit', month:'2-digit', year:'numeric' });
}
function fmtDt(iso) {
    if (!iso) return '—';
    const d = new Date(iso);
    return d.toLocaleDateString('ru-RU', { day:'2-digit', month:'2-digit' })
         + ' ' + d.toLocaleTimeString('ru-RU', { hour:'2-digit', minute:'2-digit' });
}

function showLoading(msg) {
    document.getElementById('loadStep').textContent = msg;
    document.getElementById('overlay').classList.add('on');
}
function setLoadStep(msg) { document.getElementById('loadStep').textContent = msg; }
function hideLoading() { document.getElementById('overlay').classList.remove('on'); }
function showAlert(msg) {
    document.getElementById('alertText').textContent = msg;
    document.getElementById('alertBox').style.display = '';
    document.getElementById('alertBox').scrollIntoView({ behavior: 'smooth' });
}
function hideAlert() { document.getElementById('alertBox').style.display = 'none'; }
</script>
}
