@{
    ViewData["Title"] = "Авторизация в JIRA";
    Layout = "_Layout";
}

<style>
    .auth-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .auth-card {
        max-width: 400px;
        width: 100%;
        border: none;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .auth-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 2rem;
        text-align: center;
        border-radius: 15px 15px 0 0;
    }

    .auth-body {
        padding: 2rem;
    }

    .form-control {
        padding: 12px;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        transition: all 0.3s;
    }

        .form-control:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        }

    .btn-auth {
        padding: 12px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        border-radius: 8px;
        color: white;
        font-weight: 600;
        transition: all 0.3s;
    }

        .btn-auth:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

    .auth-links {
        text-align: center;
        margin-top: 1rem;
    }
</style>

<div class="auth-container">
    <div class="card auth-card">
        <div class="auth-header">
            <h2>🔐 Авторизация</h2>
            <p class="mb-0">Войдите в систему для доступа к созданию задач</p>
        </div>
        <div class="card-body auth-body">
            <form id="authForm">
                <div class="mb-3">
                    <label for="username" class="form-label">Логин JIRA:</label>
                    <input type="text" class="form-control" id="username" name="username" placeholder="Введите ваш логин" required>
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">Пароль:</label>
                    <input type="password" class="form-control" id="password" name="password" placeholder="Введите ваш пароль" required>
                </div>

                <button type="submit" class="btn btn-auth w-100" id="loginBtn">
                    <span class="spinner-border spinner-border-sm d-none" role="status" id="loginSpinner"></span>
                    Войти в JIRA
                </button>
            </form>

            <div id="statusMessage" class="alert d-none mt-3" role="alert"></div>

            <div class="auth-links">
                <a href="@Url.Action("Index", "Home")" class="text-decoration-none">← Вернуться на главную</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/common-ui.js"></script>

    <script>
        class PasswordManager {
            constructor() {
                this._password = null;
                this._timer = null;
            }

            setPassword(password) {
                this._password = password;
                this._timer = setTimeout(() => {
                    this.clearPassword();
                    if (document.getElementById('sessionExpiredModal')) {
                        document.getElementById('sessionExpiredModal').style.display = 'block';
                    } else {
                        alert('Сессия истекла. Пожалуйста, войдите снова.');
                    }
                }, 4 * 60 * 60 * 1000);
            }

            getPassword() { return this._password; }

            clearPassword() {
                this._password = null;
                if (this._timer) {
                    clearTimeout(this._timer);
                    this._timer = null;
                }
                localStorage.removeItem('jiraUsername');
                localStorage.removeItem('lastLogin');
            }
        }

        class SecureJiraAuth {
            constructor() {
                this.passwordManager = new PasswordManager();
            }

            async login(username, password) {
                try {
                    const testAuth = btoa(`${username}:${password}`);
                    const testResponse = await fetch('https://jira.moscow.alfaintra.net/rest/api/2/myself', {
                        headers: {
                            'Authorization': `Basic ${testAuth}`,
                            'Content-Type': 'application/json'
                        }
                    });

                    if (!testResponse.ok) {
                        throw new Error('Ошибка аутентификации. Проверьте логин, пароль и VPN подключение.');
                    }

                    this.passwordManager.setPassword(password);
                    localStorage.setItem('jiraUsername', username);
                    localStorage.setItem('lastLogin', Date.now().toString());

                    return true;
                } catch (error) {
                    this.passwordManager.clearPassword();
                    throw error;
                }
            }

            logout() {
                this.passwordManager.clearPassword();
                // Больше не перенаправляем на Auth/Login - остаемся на той же странице
                window.location.reload();
            }

            isAuthenticated() {
                return !!this.passwordManager.getPassword();
            }
        }

        // Создаем глобальный экземпляр
        window.jiraAuth = new SecureJiraAuth();

        // Код для страницы логина
        document.addEventListener('DOMContentLoaded', function () {
            // Если уже авторизован, перенаправляем на главную
            if (window.jiraAuth.isAuthenticated()) {
                window.location.href = '/Jira';
                return;
            }

            const savedUsername = localStorage.getItem('jiraUsername');
            if (savedUsername) {
                document.getElementById('username').value = savedUsername;
            }
        });

        document.getElementById('authForm').addEventListener('submit', async function (e) {
            e.preventDefault();

            const username = document.getElementById('username').value;
            const password = document.getElementById('password').value;

            if (!username || !password) {
                showMessage('Заполните все поля', 'error');
                return;
            }

            try {
                showMessage('Проверка подключения к JIRA...', 'warning');
                toggleButton('loginBtn', 'loginSpinner', true);

                const success = await window.jiraAuth.login(username, password);

                if (success) {
                    showMessage('✅ Успешная авторизация! Перенаправление...', 'success');

                    setTimeout(() => {
                        window.location.href = '/Jira';
                    }, 1500);
                }
            } catch (error) {
                console.error('Login error:', error);

                if (error.message.includes('Failed to fetch')) {
                    showMessage('❌ Не удалось подключиться к JIRA. Проверьте VPN подключение.', 'error');
                } else {
                    showMessage('❌ ' + error.message, 'error');
                }
            } finally {
                toggleButton('loginBtn', 'loginSpinner', false);
            }
        });
    </script>
}