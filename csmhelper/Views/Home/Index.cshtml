@{
    ViewData["Title"] = "Портал скрам-мастера";
}

<style>
    /* Стили остаются такими же как в предыдущей версии */
    .portal-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: none;
        border-radius: 12px;
        overflow: hidden;
    }

    .portal-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    }

    .card-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .timer-card {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .task-card {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
    }

    .stats-card {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        color: white;
    }

    .portal-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 3rem 0;
        margin-bottom: 3rem;
        border-radius: 0 0 30px 30px;
    }

    .cleanup-card {
        background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
        color: white;
    }

    .vacation-card {
        background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
        color: #5a3a00;
    }

        .vacation-card .btn-light {
            color: #5a3a00;
            font-weight: 600;
        }
</style>

<div class="portal-header text-center">
    <div class="container">
        <h1 class="display-4 mb-3">🎯 Портал скрам-мастера</h1>
        <p class="lead">Инструменты для эффективного управления скрам-процессами</p>
    </div>
</div>

<div class="container">
    <!-- Основные инструменты -->
    <div class="row mb-5">
        <div class="col-md-6 mb-4">
            <a href="@Url.Action("Index", "Timer")" class="text-decoration-none">
                <div class="card portal-card timer-card h-100">
                    <div class="card-body text-center p-4">
                        <div class="card-icon">⏱️</div>
                        <h3 class="card-title">Таймер скрам-митингов</h3>
                        <p class="card-text">
                            Таймер для проведения daily standup, планирования, ретроспектив и других скрам-митингов
                        </p>
                        <div class="mt-3">
                            <span class="btn btn-light">Открыть таймер →</span>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-6 mb-4">
            <a href="@Url.Action("Index", "Jira")" class="text-decoration-none">
                <div class="card portal-card task-card h-100">
                    <div class="card-body text-center p-4">
                        <div class="card-icon">🎯</div>
                        <h3 class="card-title">Создатель задач JIRA</h3>
                        <p class="card-text">
                            Создание связанных задач в JIRA с блокирующими связями между аналитикой, разработкой и тестированием
                        </p>
                        <div class="mt-3">
                            <span class="btn btn-light">Создать задачи →</span>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4 mb-4">
            <a href="@Url.Action("Index", "Cleanup")" class="text-decoration-none">
                <div class="card portal-card cleanup-card h-100">
                    <div class="card-body text-center p-4">
                        <div class="card-icon">🗑️</div>
                        <h3 class="card-title">Очистка задач JIRA</h3>
                        <p class="card-text">
                            Удаление или перевод статусов задач по фильтрам: проекты, статусы, спринты, даты создания
                        </p>
                        <div class="mt-3">
                            <span class="btn btn-light">Очистить задачи →</span>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4 mb-4">
            <a href="@Url.Action("Index", "Gant")" class="text-decoration-none">
                <div class="card portal-card vacation-card h-100">
                    <div class="card-body text-center p-4">
                        <div class="card-icon">🏖️</div>
                        <h3 class="card-title">Диаграмма Ганта с отпусками</h3>
                        <p class="card-text">
                            Автоматическое расписание JIRA-задач с учётом графика отпусков сотрудников: планировщик пропускает дни отпуска при назначении задач
                        </p>
                        <div class="mt-3">
                            <span class="btn btn-light">Открыть планирование →</span>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- Остальная часть портала остается без изменений -->
</div>